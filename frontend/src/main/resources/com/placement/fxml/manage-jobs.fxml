<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<ScrollPane fitToWidth="true"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.placement.controller.ManageJobsController"
            style="-fx-background-color:#f0f4f8; -fx-border-color:transparent; -fx-background:#f0f4f8;"
            stylesheets="@../styles/app.css">

    <VBox styleClass="main-content" spacing="24">

        <VBox spacing="4">
            <Label text="Manage Job Drives" styleClass="page-title"/>
            <Label text="Control job status, view applicants and shortlist students."
                   styleClass="page-subtitle"/>
        </VBox>

        <!-- Jobs Table -->
        <VBox styleClass="content-card" spacing="14">
            <Label text="All Job Drives"
                   style="-fx-font-size:15px; -fx-font-weight:bold; -fx-text-fill:#1a1a2e;"/>
            <TableView fx:id="jobTable" prefHeight="220"
                       style="-fx-background-color:transparent;">
                <columns>
                    <TableColumn fx:id="colCompany" text="Company" prefWidth="140"/>
                    <TableColumn fx:id="colRole" text="Role" prefWidth="140"/>
                    <TableColumn fx:id="colPackage" text="Package" prefWidth="90"/>
                    <TableColumn fx:id="colDeadline" text="Deadline" prefWidth="100"/>
                    <TableColumn fx:id="colStatus" text="Status" prefWidth="100"/>
                    <TableColumn fx:id="colBranches" text="Branches" prefWidth="140"/>
                </columns>
            </TableView>

            <!-- Job Action Buttons -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Button text="👥 View Applicants" onAction="#handleViewEligible"
                        styleClass="apply-btn" style="-fx-padding:8 16 8 16;"/>
                <Button text="🔒 Close Applications" onAction="#handleCloseApplications"
                        style="-fx-background-color:#fed7d7; -fx-text-fill:#9b2335;
                               -fx-background-radius:6; -fx-padding:8 16 8 16;
                               -fx-cursor:hand; -fx-font-size:12px; -fx-font-weight:bold;"/>
                <Button text="📝 Move to OA" onAction="#handleMoveToOA"
                        style="-fx-background-color:#fefcbf; -fx-text-fill:#744210;
                               -fx-background-radius:6; -fx-padding:8 16 8 16;
                               -fx-cursor:hand; -fx-font-size:12px; -fx-font-weight:bold;"/>
                <Button text="🏁 Results Out" onAction="#handleResultsOut"
                        style="-fx-background-color:#c6f6d5; -fx-text-fill:#276749;
                               -fx-background-radius:6; -fx-padding:8 16 8 16;
                               -fx-cursor:hand; -fx-font-size:12px; -fx-font-weight:bold;"/>
                <Button text="🗑 Delete" onAction="#handleDeleteJob"
                        style="-fx-background-color:#e2e8f0; -fx-text-fill:#4a5568;
                               -fx-background-radius:6; -fx-padding:8 16 8 16;
                               -fx-cursor:hand; -fx-font-size:12px;"/>
            </HBox>
            <Label fx:id="selectLabel" text="← Select a job to manage"
                   style="-fx-text-fill:#718096; -fx-font-size:12px;"/>
        </VBox>

        <!-- Applicants Section -->
        <VBox styleClass="content-card" spacing="14">
            <HBox alignment="CENTER_LEFT" spacing="16">
                <Label fx:id="eligibleTitle" text="Applicants"
                       style="-fx-font-size:15px; -fx-font-weight:bold; -fx-text-fill:#1a1a2e;"
                       HBox.hgrow="ALWAYS"/>
                <Button text="✅ Shortlist Selected for OA" onAction="#handleShortlist"
                        styleClass="apply-btn" style="-fx-padding:8 16 8 16;"/>
            </HBox>

            <TableView fx:id="studentTable" prefHeight="230"
                       style="-fx-background-color:transparent;">
                <columns>
                    <TableColumn fx:id="colSelect" text="✓" prefWidth="50"/>
                    <TableColumn fx:id="colUsn" text="USN" prefWidth="110"/>
                    <TableColumn fx:id="colName" text="Name" prefWidth="150"/>
                    <TableColumn fx:id="colBranch" text="Branch" prefWidth="80"/>
                    <TableColumn fx:id="colCgpa" text="CGPA" prefWidth="70"/>
                    <TableColumn fx:id="colBacklogs" text="Backlogs" prefWidth="70"/>
                    <TableColumn fx:id="colAppStatus" text="App Status" prefWidth="140"/>
                </columns>
            </TableView>

            <Label fx:id="shortlistStatus"
                   text="Select a job above and click View Applicants."
                   style="-fx-font-size:12px; -fx-text-fill:#718096;"/>
        </VBox>

    </VBox>
</ScrollPane>