# Copy this file to .env and replace values
# Neon PostgreSQL connection URL (must include sslmode=require)
DB_URL=jdbc:postgresql://YOUR_NEON_HOST/YOUR_DATABASE?sslmode=require

# Neon PostgreSQL username
DB_USERNAME=YOUR_NEON_USERNAME

# Neon PostgreSQL password
DB_PASSWORD=YOUR_NEON_PASSWORD

# JWT signing secret (use a long random value)
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET

# JWT expiration in milliseconds (24h)
JWT_EXPIRATION=86400000
